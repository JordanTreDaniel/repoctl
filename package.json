{
  "name": "repoctl",
  "version": "0.1.0",
  "description": "Multi-repo dev environment orchestrator — isolated worktrees, ports, .env, and databases per environment",
  "type": "module",
  "bin": {
    "repoctl": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "concurrently": "^9.1.2",
    "execa": "^9.4.0",
    "js-yaml": "^4.1.0",
    "table": "^6.8.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "cli",
    "git",
    "worktree",
    "monorepo",
    "multi-repo",
    "dev-environment"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
